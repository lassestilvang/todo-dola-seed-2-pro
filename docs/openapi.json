{
  "openapi": "3.0.0",
  "info": {
    "title": "Todo Dola Seed 2 Pro API",
    "description": "A modern, full-featured task management API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Development server"
    }
  ],
  "paths": {
    "/tasks": {
      "get": {
        "summary": "List tasks",
        "description": "Retrieve a paginated list of tasks with filtering options",
        "operationId": "getTasks",
        "parameters": [
          {
            "name": "view",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["today", "next7", "upcoming", "all"]
            }
          },
          {
            "name": "listId",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "labelId",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "priority",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["high", "medium", "low", "none"]
            }
          },
          {
            "name": "completed",
            "in": "query",
            "schema": { "type": "boolean" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 100 }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "sortBy",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["date", "created", "priority", "name", "list"]
            }
          },
          {
            "name": "sortDirection",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["asc", "desc"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of tasks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Task" } },
                    "total": { "type": "integer" },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "limit": { "type": "integer" },
                        "offset": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a task",
        "operationId": "createTask",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TaskCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/Task" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{id}": {
      "get": {
        "summary": "Get a task",
        "operationId": "getTaskById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Task details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/Task" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{id}/toggle": {
      "patch": {
        "summary": "Toggle task completion",
        "operationId": "toggleTaskCompletion"
      }
    },
    "/tasks/{id}/archive": {
      "post": {
        "summary": "Archive a task",
        "operationId": "archiveTask"
      }
    }
  },
  "components": {
    "schemas": {
      "Task": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "listId": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string", "nullable": true },
          "date": { "type": "integer", "nullable": true },
          "deadline": { "type": "integer", "nullable": true },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low", "none"]
          },
          "completed": { "type": "boolean" },
          "labels": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Label" }
          },
          "subtasks": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Subtask" }
          }
        }
      },
      "TaskCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "listId": { "type": "string" },
          "description": { "type": "string" },
          "date": { "type": "integer" },
          "deadline": { "type": "integer" },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low", "none"]
          },
          "labels": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["name"]
      },
      "Label": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "emoji": { "type": "string" },
          "color": { "type": "string" }
        }
      },
      "Subtask": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "completed": { "type": "boolean" }
        }
      }
    }
  }
}